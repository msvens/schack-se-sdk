{
  "name": "@msvens/schack-se-sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for the Swedish Chess Federation (schack.se) API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.mjs",
      "require": "./dist/services/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.mjs",
      "require": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts src/services/index.ts src/types/index.ts src/utils/index.ts --format cjs,esm && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "prepare": "rm -rf dist && tsup src/index.ts src/services/index.ts src/types/index.ts src/utils/index.ts --format cjs,esm && tsc -p tsconfig.build.json --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist",
    "api:check": "bash scripts/api-check.sh",
    "api:update": "bash scripts/api-update.sh"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "chess",
    "schack",
    "ssf",
    "swedish-chess",
    "api",
    "sdk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/msvens/schack-se-sdk.git"
  },
  "author": "Martin Svensson"
}
